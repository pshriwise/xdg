get_filename_component(XDG_CMAKE_DIR "${CMAKE_CURRENT_LIST_FILE}" DIRECTORY)

include(CMakeFindDependencyMacro)

if(NOT TARGET fmt::fmt)
  find_dependency(fmt CONFIG REQUIRED)
endif()

if(NOT TARGET embree)
  find_dependency(embree @EMBREE_VERSION@ REQUIRED)
endif()

if(@XDG_ENABLE_MOAB@)
  if(NOT TARGET MOAB)
    find_dependency(MOAB REQUIRED)
  endif()
endif()

if(@XDG_ENABLE_LIBMESH@)
  include(FindPkgConfig)
  list(APPEND CMAKE_PREFIX_PATH @LIBMESH_PREFIX@)
  set(PKG_CONFIG_USE_CMAKE_PREFIX_PATH True)
  pkg_check_modules(LIBMESH REQUIRED @LIBMESH_PC_FILE@>=1.7.0 IMPORTED_TARGET)
endif()

if(NOT TARGET indicators::indicators)
  find_dependency(indicators CONFIG REQUIRED)
endif()

if(@XDG_LINK_MPI@)
  find_dependency(MPI REQUIRED)
endif()

if(@OpenMP_CXX_FOUND@)
  find_dependency(OpenMP REQUIRED)
endif()

if (NOT TARGET xdg::xdg)
    include("${XDG_CMAKE_DIR}/XDGTargets.cmake")
endif()

if (NOT TARGET xdg::xdg)
    message(FATAL_ERROR "XDG target not found")
endif()
